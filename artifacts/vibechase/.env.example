# ========================
# VibeChase Environment Variables
# ========================

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenAI (primary) — set one of these
OPENAI_API_KEY=sk-your-openai-key

# Grok/xAI (fallback — if OPENAI_API_KEY is not set, this is used)
# XAI_API_KEY=xai-your-key

# Stripe
STRIPE_SECRET_KEY=sk_test_your-stripe-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
STRIPE_PRICE_ID=price_your-pro-plan-price-id
NEXT_PUBLIC_STRIPE_PAYMENT_LINK=https://buy.stripe.com/your-payment-link

# App URL (for auth redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ========================
# WhatsApp API (Phase 2 — uncomment when ready)
# ========================
# TWILIO_ACCOUNT_SID=your-twilio-sid
# TWILIO_AUTH_TOKEN=your-twilio-token
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
#
# Or use Wati:
# WATI_API_URL=https://live-server-xxxx.wati.io
# WATI_API_TOKEN=your-wati-token
