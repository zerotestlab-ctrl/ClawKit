# VibeChase — Environment Variables
# Copy to .env.local and fill in your values.

# ── Supabase ──────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── AI (set one) ──────────────────────────────
OPENAI_API_KEY=sk-...
# XAI_API_KEY=xai-...           # Grok fallback if no OPENAI_API_KEY

# ── Stripe ────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...       # $19/mo Pro plan price ID
NEXT_PUBLIC_PAYMENT_LINK=https://buy.stripe.com/...

# ── WhatsApp (Phase 2) ───────────────────────
# TWILIO_ACCOUNT_SID=...
# TWILIO_AUTH_TOKEN=...
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# -- or Wati --
# WATI_API_URL=https://live-server-xxxx.wati.io
# WATI_API_TOKEN=...
